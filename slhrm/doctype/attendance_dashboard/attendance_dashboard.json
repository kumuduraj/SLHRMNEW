{
    "name": "Attendance Dashboard",
    "module": "SLHRM",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "is_submittable": 0,
    "issingle": 0,
    "istable": 0,
    "editable_grid": 1,
    "track_changes": 1,
    "autoname": "field:employee",
    "title_field": "employee_name",
    "search_fields": "employee,employee_name",
    "fields": [
        {
            "fieldname": "employee",
            "fieldtype": "Link",
            "label": "Employee",
            "options": "Employee",
            "reqd": 1,
            "unique": 0,
            "in_list_view": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "employee_name",
            "fieldtype": "Data",
            "label": "Employee Name",
            "fetch_from": "employee.employee_name",
            "read_only": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "column_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "date",
            "fieldtype": "Date",
            "label": "Date",
            "default": "Today",
            "reqd": 1,
            "in_list_view": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "section_break_status",
            "fieldtype": "Section Break",
            "label": "Attendance Status"
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "Present\nAbsent\nHalf Day\nOn Leave\nHoliday",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "column_break_status",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "attendance_type",
            "fieldtype": "Select",
            "label": "Type",
            "options": "Biometric\nManual\nRemote"
        },
        {
            "fieldname": "section_break_time",
            "fieldtype": "Section Break",
            "label": "Time Details"
        },
        {
            "fieldname": "check_in",
            "fieldtype": "Time",
            "label": "Check In"
        },
        {
            "fieldname": "column_break_time",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "check_out",
            "fieldtype": "Time",
            "label": "Check Out"
        },
        {
            "fieldname": "section_break_stats",
            "fieldtype": "Section Break",
            "label": "Statistics"
        },
        {
            "fieldname": "working_hours",
            "fieldtype": "Float",
            "label": "Working Hours",
            "read_only": 1
        },
        {
            "fieldname": "column_break_stats",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "overtime_hours",
            "fieldtype": "Float",
            "label": "Overtime Hours"
        },
        {
            "fieldname": "section_break_notes",
            "fieldtype": "Section Break",
            "label": "Notes"
        },
        {
            "fieldname": "notes",
            "fieldtype": "Small Text",
            "label": "Notes"
        }
    ],
    "permissions": [
        {
            "role": "HR Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "export": 1,
            "report": 1
        },
        {
            "role": "Employee",
            "read": 1,
            "write": 0,
            "create": 0
        }
    ]
}
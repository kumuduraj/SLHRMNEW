[
  {
    "doctype": "Custom Field",
    "dt": "Employee",
    "module": "SLHRM",
    "fieldname": "biometric_section",
    "fieldtype": "Section Break",
    "label": "Biometric Attendance",
    "insert_after": "column_break_4",
    "name": "Employee-biometric_section"
  },
  {
    "doctype": "Custom Field",
    "dt": "Employee",
    "module": "SLHRM",
    "fieldname": "biometric_device_id",
    "fieldtype": "Data",
    "label": "Biometric Device ID",
    "insert_after": "biometric_section",
    "description": "Employee ID as registered on the biometric device",
    "name": "Employee-biometric_device_id"
  },
  {
    "doctype": "Custom Field",
    "dt": "Employee",
    "module": "SLHRM",
    "fieldname": "biometric_device_name",
    "fieldtype": "Data",
    "label": "Device Name",
    "insert_after": "biometric_device_id",
    "read_only": 1,
    "name": "Employee-biometric_device_name"
  },
  {
    "doctype": "Custom Field",
    "dt": "User",
    "module": "SLHRM",
    "fieldname": "slhrm_must_change_password",
    "fieldtype": "Check",
    "label": "SLHRM: Must Change Password",
    "insert_after": "last_password_reset_date",
    "default": "0",
    "read_only": 1,
    "hidden": 1,
    "description": "Set to 1 when User is auto-created from Employee. Cleared after first password change in SLHRM PWA.",
    "name": "User-slhrm_must_change_password"
  },
  {
    "doctype": "Custom Field",
    "dt": "Salary Structure Assignment",
    "module": "SLHRM",
    "fieldname": "custom_basic_salary",
    "fieldtype": "Currency",
    "label": "Basic Salary",
    "insert_after": "base",
    "allow_on_submit": 1,
    "description": "Basic Salary amount for this employee",
    "name": "Salary Structure Assignment-custom_basic_salary"
  },
  {
    "doctype": "Custom Field",
    "dt": "Salary Structure Assignment",
    "module": "SLHRM",
    "fieldname": "custom_base_allowance",
    "fieldtype": "Currency",
    "label": "Base Allowance",
    "insert_after": "custom_basic_salary",
    "allow_on_submit": 1,
    "description": "Base Allowance amount for this employee",
    "name": "Salary Structure Assignment-custom_base_allowance"
  },
  {
    "doctype": "Custom Field",
    "dt": "Salary Structure Assignment",
    "module": "SLHRM",
    "fieldname": "custom_vehicle_allowance",
    "fieldtype": "Currency",
    "label": "Vehicle Allowance",
    "insert_after": "custom_base_allowance",
    "allow_on_submit": 1,
    "description": "Vehicle Allowance amount for this employee",
    "name": "Salary Structure Assignment-custom_vehicle_allowance"
  }
